APP_NAME=apptaro Backend
APP_ENV=development
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=*
SUPPORT_USERNAME=@your_tracksupport
SUPPORT_MAX_URL=https://max.ru/
OFFER_URL=https://dimonk95.github.io/slide_ai/

KIE_API_KEY=
KIE_BASE_URL=https://api.kie.ai
KIE_TEXT_MODEL=gemini-flash
KIE_TEXT_ENDPOINT=
KIE_TEXT_FALLBACK_MODELS=gemini-2.5-flash,gemini-3-pro
KIE_IMAGE_MODEL=flux-nano-banana
KIE_IMAGE_ENDPOINT=

REPLICATE_API_TOKEN=
REPLICATE_BASE_URL=https://api.replicate.com
REPLICATE_MODEL=black-forest-labs/flux-schnell
REPLICATE_DEFAULT_INPUT=
REPLICATE_TEXT_MODEL=google/gemini-3-flash
REPLICATE_TEXT_PROMPT_FIELD=prompt
REPLICATE_WAIT_SECONDS=60
REPLICATE_POLL_INTERVAL=1.5
REPLICATE_TIMEOUT_SECONDS=120
REPLICATE_TEXT_DEFAULT_INPUT=

LIBREOFFICE_PATH=soffice
FONT_FALLBACK=Cambria
FONT_WHITELIST=Cambria,Calibri,Arial,Times New Roman
FONTS_DIR=runtime/fonts
DATA_DIR=data
DATABASE_PATH=data/appslides.db
IMAGE_CONCURRENCY=5
IMAGE_GENERATION_RETRIES=2
IMAGE_GENERATION_RETRY_DELAY_SECONDS=2.0
TEMP_DIR=runtime/temp
TEMPLATES_DIR=runtime/templates
TAROT_CARDS_DIR=runtime/tarot/cards
TAROT_BACKGROUND_PATH=runtime/tarot/backgrounds/main.png
TAROT_LAYOUT_PATH=runtime/tarot/layout.json

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET=
