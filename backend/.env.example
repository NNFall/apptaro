YOOKASSA_POLL_INTERVAL=10
YOOKASSA_POLL_TIMEOUT=600
YOOKASSA_RECEIPT_EMAIL=
YOOKASSA_RECEIPT_PHONE=
YOOKASSA_TAX_SYSTEM_CODE=1
YOOKASSA_VAT_CODE=1
YOOKASSA_ITEM_NAME=Подписка на расклады apptaro
YOOKASSA_PAYMENT_SUBJECT=service
YOOKASSA_PAYMENT_MODE=full_prepayment
YOOKASSA_TEST_MODE=1
AUTO_RENEW_INTERVAL=60
ADMIN_BOT_TOKEN=
ADMIN_IDS=
